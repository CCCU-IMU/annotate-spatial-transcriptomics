{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CCCU-IMU/annotate-spatial-transcriptomics/schemas/atlas_index_manifest.schema.json",
  "title": "Reusable efficient Atlas mapping index",
  "type": "object",
  "required": [
    "schema_version", "reference_id", "mapping_engine", "n_reference",
    "n_dimensions", "feature_transform", "reference_representation",
    "broad_crosswalk", "dense_pairwise_matrix", "query_reference_joint_retraining",
    "whole_object_rctd", "reusable_across_queries"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "reference_id": {"type": "string", "minLength": 1},
    "mapping_engine": {"enum": ["fixed_projection_ann", "fixed_projection_prototype", "diagnostic_exact_knn_small_reference"]},
    "n_reference": {"type": "integer", "minimum": 1},
    "n_dimensions": {"type": "integer", "minimum": 1},
    "feature_transform": {"$ref": "#/$defs/artifact"},
    "reference_representation": {"$ref": "#/$defs/artifact"},
    "neighbor_index": {"$ref": "#/$defs/artifact"},
    "broad_crosswalk": {"$ref": "#/$defs/artifact"},
    "dense_pairwise_matrix": {"const": false},
    "query_reference_joint_retraining": {"const": false},
    "whole_object_rctd": {"const": false},
    "reusable_across_queries": {"const": true}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
